import os
import json
import logging

# إعدادات الـ Logging حتى تشوف التفاصيل بالـ Railway
logging.basicConfig(level=logging.INFO)
logger = logging.getLogger(__name__)

# خريطة تحويل قيم SameSite لكي تتوافق مع المتصفحات (مثل Playwright)
SAMESITE_MAP = {
    "lax": "Lax",
    "strict": "Strict",
    "none": "None",
    "no_restriction": "None"
}

def prepare_cookies(cookies_list):
    prepared = []
    for c in cookies_list:
        # حل مشكلة الـ null بشكل جذري:
        # إذا جانت القيمة فارغة أو null، راح نستخدم "Lax" كقيمة افتراضية
        raw_same_site = c.get('sameSite')
        if raw_same_site is None:
            same_site_val = "Lax"
        else:
            # هنا نحولها لنص ونلغي الأحرف الكبيرة حتى تطابق الخريطة بدون أخطاء
            same_site_val = SAMESITE_MAP.get(str(raw_same_site).lower(), "Lax")

        prepared_cookie = {
            'name': c.get('name', ''),
            'value': c.get('value', ''),
            'domain': c.get('domain', ''),
            'path': c.get('path', '/'),
            'secure': c.get('secure', True),
            'httpOnly': c.get('httpOnly', False),
            'sameSite': same_site_val
        }
        
        # تحويل تاريخ الانتهاء إذا جان موجود ومو null
        if 'expirationDate' in c and c['expirationDate'] is not None:
            prepared_cookie['expires'] = float(c['expirationDate'])
            
        prepared.append(prepared_cookie)
    return prepared

# 1. تحميل ملف الكوكيز بأمان
try:
    with open('cookies.json', 'r', encoding='utf-8') as f:
        NETFLIX_COOKIES = json.load(f)
    logger.info("تم تحميل ملف cookies.json بنجاح.")
except FileNotFoundError:
    logger.error("خطأ: ملف cookies.json غير موجود!")
    NETFLIX_COOKIES = []
except json.JSONDecodeError:
    logger.error("خطأ: ملف cookies.json يحتوي على أخطاء في صيغة الـ JSON!")
    NETFLIX_COOKIES = []

# 2. تحضير الكوكيز للعمل مع Playwright بدون أي كراش
PLAYWRIGHT_COOKIES = prepare_cookies(NETFLIX_COOKIES)
logger.info(f"تمت معالجة وتحضير {len(PLAYWRIGHT_COOKIES)} كوكيز بنجاح.")

